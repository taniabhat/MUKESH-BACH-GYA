# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------

APP_NAME=ResearchOS
APP_VERSION=1.0.0

ENVIRONMENT=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

SECRET_KEY=replace_with_secure_secret_key

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/researchos

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333

NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ------------------------------------------------------------------
# OpenRouter
# ------------------------------------------------------------------

OPENROUTER_API_KEY=your_openrouter_api_key

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

QWEN3_MODEL=qwen/qwen3-14b
DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324
PHI3_MODEL=microsoft/phi-3-mini-128k-instruct

# ------------------------------------------------------------------
# Services
# ------------------------------------------------------------------

GROBID_URL=http://grobid:8070

DATA_DIR=/data

SANDBOX_IMAGE=research-os-sandbox:latest

# ------------------------------------------------------------------
# APIs
# ------------------------------------------------------------------

S2_API_KEY=

CROSSREF_EMAIL=you@example.com