EMBEDDING_PROVIDER=huggingface

EMBEDDING_MODEL=BAAI/bge-m3

EMBEDDING_API_KEY=hf_xxxxxxxxx

# ============================================================
# Research APIs
# ============================================================

OPENALEX_API_KEY=

OPENALEX_EMAIL=your@email.com

CROSSREF_MAILTO=your@email.com

SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# Runtime
# ============================================================

LOG_LEVEL=INFO

DEBUG=false
