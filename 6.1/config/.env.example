# =========================================================
# LLM
# =========================================================

LLM_PROVIDER=huggingface

LLM_MODEL=Qwen/Qwen3-14B-Instruct

LLM_API_KEY=hf_xxxxxxxxx

LLM_BASE_URL=https://api-inference.huggingface.co

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# =========================================================
# EMBEDDINGS
# =========================================================

EMBEDDING_PROVIDER=huggingface

EMBEDDING_MODEL=BAAI/bge-m3

EMBEDDING_API_KEY=hf_xxxxxxxxx

EMBEDDING_BASE_URL=https://api-inference.huggingface.co

EMBEDDING_DEVICE=cuda

# =========================================================
# OPENALEX
# =========================================================

OPENALEX_EMAIL=you@example.com

# =========================================================
# CROSSREF
# =========================================================

CROSSREF_MAILTO=you@example.com

# =========================================================
# STORAGE
# =========================================================

STORAGE_DIR=/tmp/research_discovery

# =========================================================
# LOGGING
# =========================================================

LOG_LEVEL=INFO
DEBUG=false