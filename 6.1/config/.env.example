# ============================================================
# Research Discovery Module — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# -------------------------------------------------------
# LLM Backend (choose one)
# -------------------------------------------------------

# Set to true to use vLLM (production GPU server)
# Set to false (default) to use Ollama (local dev)
USE_VLLM=false

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# vLLM server URL (OpenAI-compatible)
VLLM_BASE_URL=http://localhost:8080/v1

# Model name to use for query expansion
# Ollama: "qwen3:14b", "qwen3:7b", "qwen3:4b" (smaller = faster)
# vLLM:   match the model name you loaded into vLLM
QWEN3_MODEL=qwen3:14b

# -------------------------------------------------------
# Embeddings
# -------------------------------------------------------

# Local embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=BAAI/bge-m3

# Device: "cuda" (GPU), "cpu" (no GPU)
EMBEDDING_DEVICE=cuda

# Where to cache downloaded models
MODEL_CACHE_DIR=/tmp/models

# -------------------------------------------------------
# Research APIs (all free — only email required for polite pool)
# -------------------------------------------------------

# Your email — used in OpenAlex + CrossRef "polite pool" headers
# Gives higher rate limits. Use a real email.
OPENALEX_EMAIL=yourname@institution.edu
CROSSREF_MAILTO=yourname@institution.edu

# Semantic Scholar API key (optional — free tier works without it)
# Get one at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# -------------------------------------------------------
# Storage
# -------------------------------------------------------
STORAGE_DIR=/tmp/research_discovery

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
LOG_LEVEL=INFO
DEBUG=false